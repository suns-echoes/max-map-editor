# The loop-walk shores it but strands a couple of broken seams at the
# steep folds (it does not auto-repair).
shore alt
assert-hash 0xa2d8591ec59b8095

# `shore fix` re-tiles the broken windows and closes them.
shore fix
assert-hash 0xb87dff37db49fc01

# Idempotent: a clean coast has nothing to fix.
shore fix
assert-hash 0xb87dff37db49fc01

# One undo unit: back to the broken state.
undo
assert-hash 0xa2d8591ec59b8095
redo
assert-hash 0xb87dff37db49fc01

